{
	"name": "sveltekit-github-stats",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "vp check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && prettier --check \"**/*.svelte\"",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "vp check --fix && prettier --write \"**/*.svelte\"",
		"lint": "vp check && prettier --check \"**/*.svelte\"",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.4",
		"@types/d3-scale": "^4.0.9",
		"@types/node": "^25.6.0",
		"@vitest/browser-playwright": "^4.1.5",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"d3-scale": "^4.0.2",
		"layerchart": "2.0.0-next.54",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"valibot": "^1.3.1",
		"vite": "^8.0.10",
		"vite-plus": "^0.1.19",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	}
}
